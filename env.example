# ─────────────────────────────────────────────────────────
#  Job AI Agent FREE — Environment Variables
#  Copy this file to .env and fill in your values
#  ALL services below are FREE — no credit card needed
# ─────────────────────────────────────────────────────────

# ── GROQ API (Free AI — no credit card required) ─────────
# Steps to get your FREE key:
#   1. Go to https://console.groq.com
#   2. Sign up with Google or email (free)
#   3. Click "API Keys" → "Create API Key"
#   4. Copy and paste it below
GROQ_API_KEY=your_groq_api_key_here

# ── GMAIL (Free — uses App Password) ─────────────────────
# Your Gmail address
GMAIL_ADDRESS=your.email@gmail.com

# Gmail App Password (NOT your real password — see README)
# Steps:
#   1. Go to myaccount.google.com/security
#   2. Enable 2-Step Verification
#   3. Go to myaccount.google.com/apppasswords
#   4. Generate → copy the 16-character code here
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ── YOUR CV PATH ──────────────────────────────────────────
# Put your CV PDF inside the assets/ folder
# Then update this path to match your filename
CV_PATH=./assets/Jasper_John_Paitan_CV.pdf
